{
  "info": {
    "_postman_id": "c1b2b0f3-6f6c-4d30-b6cc-5e44a3c4c6e1",
    "name": "Flu Vax Strapi API Flow",
    "description": "Postman collection for the Strapi event-portal plugin. Run the folders in order, or run the whole collection. Core CRUD requests use `strapiToken`, which can be either a Strapi API token or a JWT obtained from the optional login request. The flow creates dependent records in order: mandatory field -> user partition -> user group -> contact info -> event template -> event -> event slot -> ERP hold -> ERP booking -> audit log lookup, then deletes them in reverse order.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('strapiBaseUrl')) {",
          "  pm.collectionVariables.set('strapiBaseUrl', 'http://localhost:1337');",
          "}",
          "",
          "const token = pm.collectionVariables.get('strapiToken');",
          "const url = pm.request.url.toString();",
          "",
          "if (token && !url.includes('/api/auth/local')) {",
          "  pm.request.headers.upsert({ key: 'Authorization', value: `Bearer ${token}` });",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "strapiBaseUrl",
      "value": "http://localhost:1337"
    },
    {
      "key": "publicBaseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "adminEmail",
      "value": "admin@example.com"
    },
    {
      "key": "adminPassword",
      "value": "changeme"
    },
    {
      "key": "strapiToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "00 Auth And Init",
      "item": [
        {
          "name": "Login And Store JWT",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"identifier\":\"{{adminEmail}}\",\"password\":\"{{adminPassword}}\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{strapiBaseUrl}}/api/auth/local",
              "host": [
                "{{strapiBaseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "local"
              ]
            },
            "description": "Optional. Use this if you want the collection to obtain a users-permissions JWT instead of manually setting `strapiToken` to a Strapi API token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.expect(json.jwt).to.be.a('string');",
                  "pm.collectionVariables.set('strapiToken', json.jwt);"
                ]
              }
            }
          ]
        },
        {
          "name": "Init Run Context",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{strapiBaseUrl}}/api/portal/eap/dashboard",
              "host": [
                "{{strapiBaseUrl}}"
              ],
              "path": [
                "api",
                "portal",
                "eap",
                "dashboard"
              ]
            },
            "description": "Generates a fresh run id and all derived variables used by later requests."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function isoDate(offsetDays) {",
                  "  const date = new Date();",
                  "  date.setUTCDate(date.getUTCDate() + offsetDays);",
                  "  return date.toISOString().slice(0, 10);",
                  "}",
                  "",
                  "const runId = `${Date.now().toString(36)}${Math.random().toString(36).slice(2, 6)}`;",
                  "const vars = pm.collectionVariables;",
                  "",
                  "[",
                  "  'mandatoryFieldDocumentId',",
                  "  'userPartitionDocumentId',",
                  "  'userGroupDocumentId',",
                  "  'contactInfoDocumentId',",
                  "  'eventTemplateDocumentId',",
                  "  'eventDocumentId',",
                  "  'eventSlotDocumentId',",
                  "  'holdToken',",
                  "  'appointmentHoldDocumentId',",
                  "  'appointmentDocumentId',",
                  "  'auditLogDocumentId',",
                  "  'cancelToken'",
                  "].forEach((key) => vars.unset(key));",
                  "",
                  "vars.set('runId', runId);",
                  "vars.set('mandatoryFieldKey', `participant_name_${runId}`);",
                  "vars.set('partitionCode', `PT-${runId}`.toUpperCase());",
                  "vars.set('partitionSlug', `pt-${runId}`);",
                  "vars.set('groupCode', `GRP-${runId}`.toUpperCase());",
                  "vars.set('contactTitle', `Support ${runId}`);",
                  "vars.set('templateName', `Template ${runId}`);",
                  "vars.set('eventName', `Vaccination Event ${runId}`);",
                  "vars.set('participantName', `Portal QA ${runId}`);",
                  "vars.set('participantEmail', `qa+${runId}@example.com`);",
                  "vars.set('participantMobile', `9000${String(Math.floor(Math.random() * 9000) + 1000)}`);",
                  "vars.set('registrationStartDate', isoDate(-1));",
                  "vars.set('registrationEndDate', isoDate(14));",
                  "vars.set('eventStartDate', isoDate(7));",
                  "vars.set('eventEndDate', isoDate(7));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('dashboard smoke check passed', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.expect(json.headline).to.eql('EAP overview');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
