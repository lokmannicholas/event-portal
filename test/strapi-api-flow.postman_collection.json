                  "pm.expect(json.data[0].appointmentHoldStatus).to.eql('ACTIVE');"
                ]
              }
            }
          ]
        },
        {
          "name": "Create ERP Booking",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"eventDocumentId\":\"{{eventDocumentId}}\",\"eventSlotDocumentId\":\"{{eventSlotDocumentId}}\",\"holdToken\":\"{{holdToken}}\",\"participantName\":\"{{participantName}}\",\"staffNumber\":\"STAFF-{{runId}}\",\"registeredEmail\":\"{{participantEmail}}\",\"mobileNumber\":\"{{participantMobile}}\",\"communicationPreference\":\"EMAIL\",\"termsAccepted\":true,\"formValues\":{\"participant_name\":\"{{participantName}}\"}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{strapiBaseUrl}}/api/portal/erp/bookings",
              "host": [
                "{{strapiBaseUrl}}"
              ],
              "path": [
                "api",
                "portal",
                "erp",
                "bookings"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('booking created', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('appointmentDocumentId', json.documentId);",
                  "pm.collectionVariables.set('cancelToken', json.cancelToken);",
                  "pm.expect(json.eventDocumentId).to.eql(pm.collectionVariables.get('eventDocumentId'));",
                  "pm.expect(json.status).to.eql('CONFIRMED');"
                ]
              }
            }
          ]
        },
