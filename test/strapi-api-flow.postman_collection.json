                "exec": [
                  "pm.test('partition relation lookup succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "const groups = json.data.userGroups || [];",
                  "pm.expect(groups.some((group) => group.documentId === pm.collectionVariables.get('userGroupDocumentId'))).to.eql(true);"
                ]
              }
            }
          ]
        },
