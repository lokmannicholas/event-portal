              "raw": "{\"data\":{\"name\":\"{{templateName}}\",\"description\":\"Postman template {{runId}}\",\"companyName\":\"Acme Health\",\"location\":\"Central Clinic\",\"eventName\":\"{{eventName}}\",\"eventDescription\":\"Template-driven flu vaccination event\",\"defaultEventStartDate\":\"{{eventStartDate}}\",\"defaultEventEndDate\":\"{{eventEndDate}}\",\"dayStartTime\":\"09:00:00.000\",\"dayEndTime\":\"10:00:00.000\",\"timeslotDurationMinutes\":30,\"quotaPerSlot\":4,\"registrationStartDate\":\"{{registrationStartDate}}\",\"registrationEndDate\":\"{{registrationEndDate}}\",\"eventTemplateStatus\":\"ACTIVE\",\"userPartition\":\"{{userPartitionDocumentId}}\",\"formFields\":[{\"fieldKey\":\"participant_name\",\"labelEn\":\"Participant name\",\"fieldType\":\"TEXT\",\"required\":true,\"visibleInErp\":true,\"visibleInEcp\":true,\"visibleInEap\":true,\"sortOrder\":10}]}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
