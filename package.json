{
  "name": "flu-vaccination-platform",
  "private": true,
  "packageManager": "yarn@4.2.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:event-portal": "yarn workspace @flu-vax/event-portal dev",
    "dev:cms": "yarn workspace @flu-vax/cms develop",
    "build:event-portal": "yarn workspace @flu-vax/event-portal build",
    "build:cms": "yarn workspace @flu-vax/cms build",
    "build": "yarn build:event-portal && yarn build:cms",
    "typecheck:event-portal": "yarn workspace @flu-vax/event-portal typecheck",
    "typecheck:cms": "yarn workspace @flu-vax/cms typecheck",
    "typecheck": "yarn typecheck:event-portal && yarn typecheck:cms"
  }
}
